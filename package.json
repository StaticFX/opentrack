{
  "name": "opentrack",
  "version": "0.1.0",
  "description": "Open, public-by-default issue tracker with GitHub sync",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "worker": "tsx --tsconfig tsconfig.scripts.json src/lib/server/jobs/worker-entry.ts",
    "seed": "tsx --tsconfig tsconfig.scripts.json scripts/seed.ts",
    "smoke": "tsx --tsconfig tsconfig.scripts.json scripts/smoke.ts",
    "smoke:import": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-import.ts",
    "smoke:notify": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-notify.ts",
    "smoke:discord": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-discord.ts",
    "smoke:views": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-views.ts",
    "smoke:search": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-search.ts",
    "smoke:roadmap": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-roadmap.ts",
    "smoke:reactions": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-reactions.ts",
    "smoke:feeds": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-feeds.ts",
    "smoke:checklists": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-checklists.ts",
    "smoke:merge": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-merge.ts",
    "smoke:changelog": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-changelog.ts",
    "smoke:bulk": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-bulk.ts",
    "smoke:staleness": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-staleness.ts",
    "smoke:analytics": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-analytics.ts",
    "smoke:profiles": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-profiles.ts",
    "smoke:apikeys": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-apikeys.ts",
    "smoke:fields": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-fields.ts",
    "smoke:oauth": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-oauth.ts",
    "smoke:github-sync": "tsx --tsconfig tsconfig.scripts.json scripts/smoke-github-sync.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.56.4",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.8.1",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "@libsql/client": "^0.15.0",
    "@lucide/svelte": "^1.23.0",
    "@node-rs/argon2": "^2.0.2",
    "@octokit/app": "^16.1.2",
    "@octokit/webhooks": "^14.2.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.2",
    "isomorphic-dompurify": "^3.18.0",
    "marked": "^18.0.5",
    "octokit": "^5.0.5",
    "otpauth": "^9.5.1",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "svelte-dnd-action": "^0.9.70",
    "valibot": "^1.4.2",
    "web-push": "^3.6.7"
  }
}
