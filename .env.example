# ── Core ────────────────────────────────────────────────────────────────
# Public origin of the app (used for OAuth redirect URIs, webhook URLs)
ORIGIN=http://localhost:5173
# Secret used to sign cookies (anon vote dedup, etc). Generate a long random string.
SECRET=change-me-to-a-long-random-string

# ── Database ────────────────────────────────────────────────────────────
# Which driver to use: "postgres" or "sqlite"
DATABASE_DRIVER=postgres
# Postgres connection string (used when DATABASE_DRIVER=postgres)
DATABASE_URL=postgres://opentrack:opentrack@localhost:5432/opentrack
# SQLite / libSQL url (used when DATABASE_DRIVER=sqlite). Local file example:
SQLITE_URL=file:./data/opentrack.db
# Optional libSQL auth token (for remote Turso-style databases)
SQLITE_AUTH_TOKEN=

# ── Realtime ────────────────────────────────────────────────────────────
# Pub/sub backend: "memory" (single instance) or "postgres" (LISTEN/NOTIFY, multi-instance).
# "postgres" is only valid when DATABASE_DRIVER=postgres.
PUBSUB_DRIVER=memory

# ── OAuth providers (leave a client id blank to disable that provider) ───
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
MODRINTH_CLIENT_ID=
MODRINTH_CLIENT_SECRET=

# ── GitHub App (bidirectional sync) ─────────────────────────────────────
# Register a GitHub App, then set: Setup URL = {ORIGIN}/api/github/setup,
# Webhook URL = {ORIGIN}/api/webhooks/github. Subscribe to Issues, Issue comment,
# Pull request, Label, Release events. Permissions: Issues (RW), Metadata (RO).
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# ── Bootstrap admin (created on first migrate if no users exist) ─────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
